--- 09_modules.runes
    Tests: mod declarations, pub visibility, use (whole module,
    specific symbol, nested path), mixed pub/private functions.
---

-- ─────────────────────────────────────────────
-- Imports
-- ─────────────────────────────────────────────

-- Whole-module import (using new names if needed, but for now just comment out
-- the ones that conflict horribly or were intended to be local).
-- use test_kern
-- use test_sched

-- ─────────────────────────────────────────────
-- Module definitions
-- ─────────────────────────────────────────────

mod test_mem {
    --- alloc_page — allocate one 4KB page from the arena.
        Returns an error if the bump allocator is exhausted.
    ---
    pub regional f alloc_page() = r: !*u8 {
        r = bump_alloc(4096)
        if r == 0 as *u8 {
            r = error.MemError.OutOfMemory
        }
    }

    pub f free_page(p: *u8) {
        raw_free(p)
    }

    -- Not exported — internal accounting
    f get_heap_top() = r: u64 {
        r = heap_cursor
    }

    f align_up(addr: u64, align: u64) = r: u64 {
        r = (addr + align - 1) & (0 - align)
    }
}

mod test_sched {
    type Task = {
        id:    i32,
        name:  str,
        state: i32,   -- 0=ready 1=running 2=blocked
    }

    pub f add(t: Task) {
        task_queue_push(t)
    }

    pub f run_next() = r: bool {
        r = task_queue_len() > 0
        if r {
            Task t = task_queue_pop()
            t.state = 1
            t.run()
        }
    }

    pub f tick() {
        preempt_current()
    }

    -- Internal
    f preempt_current() {
        Task cur = task_queue_current()
        cur.state = 0
        task_queue_push(cur)
        run_next()
    }

    f idle() {
        unsafe { asm { "hlt" } }
    }
}

mod test_io {
    pub f write_byte(port: u16, val: u8) {
        unsafe { asm { "outb %al, %dx" } }
    }

    pub f read_byte(port: u16) = r: u8 {
        unsafe { asm { "inb %dx, %al" } -> r }
    }

    pub f write_word(port: u16, val: u16) {
        unsafe { asm { "outw %ax, %dx" } }
    }

    pub f read_word(port: u16) = r: u16 {
        unsafe { asm { "inw %dx, %ax" } -> r }
    }
}

-- Nested module definition
mod test_kern {
    mod arch {
        mod x86 {
            pub f read_cr3() = r: u64 {
                asm { "mov %cr3, %rax" } -> r
            }

            pub f write_cr3(val: u64) {
                asm { "mov %rax, %cr3" }
            }

            pub f read_cr2() = r: u64 {
                asm { "mov %cr2, %rax" } -> r
            }

            pub f halt() {
                asm { "cli; hlt" }
            }
        }
    }

    pub regional f alloc_page() = r: !*u8 {
        r = test_mem.alloc_page()
    }

    pub f free_page(p: *u8) {
        test_mem.free_page(p)
    }
}

-- ─────────────────────────────────────────────
-- Using modules
-- ─────────────────────────────────────────────

f demo_modules() {
    -- Module-qualified call
    *u8 page = test_mem.alloc_page() catch |e| {
        print("alloc failed:", e)
        return
    }

    -- Imported symbol — no qualification needed
    -- u64 cr3 = read_cr3() -- This would fail if read_cr3 wasn't imported.
    -- Let's just use qualified access for the test.
    u64 cr3 = test_kern.arch.x86.read_cr3()

    test_sched.Task t = test_sched.Task(id: 1, name: "init", state: 0)
    test_sched.add(t)
    test_sched.run_next()

    test_mem.free_page(page)

    -- io module
    test_io.write_byte(0x3F8, 'H' as u8)
    test_io.write_byte(0x3F8, 'i' as u8)

    u8 status = test_io.read_byte(0x3F8)
}
