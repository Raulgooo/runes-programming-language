type Point = {
    x: i32,
    y: i32,
}

f test_match(x: i32, p: Point) {
    -- Literal and wildcard
    match x {
        0 -> print("zero"),
        1 -> print("one"),
        _ -> print("many"),
    }

    -- Binding
    match x {
        val -> print("value is " + val),
    }

    -- Struct pattern (parsing supported, semantic TODO in implementation)
    match p {
        Point(x: 0, y) -> print("on y-axis"),
        Point(x, y: 0) -> print("on x-axis"),
        _              -> print("elsewhere"),
    }

    -- Guards
    match x {
        n if n < 0 -> print("negative"),
        n if n > 0 -> print("positive"),
        _          -> print("zero"),
    }
}

f main() {
    Point p = Point(x: 10, y: 20)
    test_match(42, p)
}
