type Vec2 = {
    x: f32 = 0.0,
    y: f32 = 0.0,
}

method Vec2 {
    f length(self) = r: f32 {
        r = 1.0 -- simplified
    }

    f scale(self, factor: f32) = r: Vec2 {
        r = Vec2(x: self.x * factor, y: self.y * factor)
    }
}

pub f main() {
    Vec2 v = Vec2(x: 3.0, y: 4.0)
    f32 cx = v.x
    f32 cy = v.y

    f32 len = v.length()
    Vec2 v2 = v.scale(2.0)

    *Vec2 pv = &v
    f32 px = pv.x -- auto-dereference
}
