--- 10_kernel_bootstrap.runes
    Integration test — a complete, self-consistent kernel source file.
    Exercises almost every v0.1 construct in one realistic context:
    extern, attributes, structs, methods, error sets, !T, try/catch,
    match, unsafe, asm, volatile, memory strategies, promote, tuples,
    pub, nested functions, modules, for loops, while, loop + break.
---

use kernel.arch.x86

-- ─────────────────────────────────────────────
-- extern — C / linker symbols
-- ─────────────────────────────────────────────

extern f memset(ptr: *u8, val: i32, len: usize)
extern f memcpy(dst: *u8, src: *u8, len: usize)
extern f memcmp(a: *u8, b: *u8, len: usize) = r: i32

extern u64 BSS_START
extern u64 BSS_END
extern u64 KERNEL_START
extern u64 KERNEL_END

-- ─────────────────────────────────────────────
-- Error sets
-- ─────────────────────────────────────────────

error MapError = {
    | AlreadyMapped
    | InvalidAddress
    | OutOfMemory
}

error TaskError = {
    | SpawnFailed
    | InvalidEntry
    | QueueFull
}

error IoError = {
    | Timeout
    | BadPort
    | Overrun
}

-- ─────────────────────────────────────────────
-- Struct layout — kernel types
-- ─────────────────────────────────────────────

#[packed]
#[align(4096)]
type PageTable = {
    entries: [512]u64,
}

#[repr(C)]
type SyscallFrame = {
    rax: u64,
    rbx: u64,
    rcx: u64,
    rdx: u64,
    rsi: u64,
    rdi: u64,
}

#[repr(C)]
type InterruptFrame = {
    rip:    u64,
    cs:     u64,
    rflags: u64,
    rsp:    u64,
    ss:     u64,
}

type Task = {
    id:    i32,
    name:  str,
    state: i32,
}

-- ─────────────────────────────────────────────
-- Linker-placed sections
-- ─────────────────────────────────────────────

#[section(".bss.stack")]
#[align(4096)]
[16384]u8 KERNEL_STACK = []

#[section(".rodata.gdt")]
const [8]u64 GDT = []

-- ─────────────────────────────────────────────
-- PageTable methods
-- ─────────────────────────────────────────────

method PageTable {
    regional f new() = t: PageTable {
        t = PageTable(entries: [])
    }

    f map(self, vaddr: u64, paddr: u64, flags: u64) = r: !void {
        if (vaddr & 0xFFF) != 0 {
            r = error.MapError.InvalidAddress
            return
        }

        u64 idx = (vaddr >> 12) & 0x1FF

        if self.entries[idx] != 0 {
            r = error.MapError.AlreadyMapped
        } else {
            self.entries[idx] = paddr | flags
        }
    }

    f unmap(self, vaddr: u64) {
        u64 idx = (vaddr >> 12) & 0x1FF
        self.entries[idx] = 0
    }

    f is_mapped(self, vaddr: u64) = r: bool {
        u64 idx = (vaddr >> 12) & 0x1FF
        r = self.entries[idx] != 0
    }
}

-- ─────────────────────────────────────────────
-- volatile MMIO helpers
-- ─────────────────────────────────────────────

f uart_putc(ch: u8) {
    volatile *u32 uart = 0x10000000 as *u32
    *uart = ch as u32
}

f uart_puts(s: str) {
    for (0..s.len) |i| {
        uart_putc(*(s.ptr + i))
    }
}

f uart_ready() = r: bool {
    volatile *u8 lsr = 0x10000005 as *u8
    r = (*lsr & 0x20) != 0
}

-- ─────────────────────────────────────────────
-- Interrupt handlers
-- ─────────────────────────────────────────────

#[interrupt]
f page_fault_handler() {
    u64 cr2 = read_cr2()

    match handle_page_fault(cr2) {
        Ok(_)  -> {},
        Err(e) -> {
            uart_puts("page fault: unhandled\n")
            loop { unsafe { asm { "cli; hlt" } } }
        },
    }
}

#[interrupt]
f double_fault_handler() {
    uart_puts("DOUBLE FAULT\n")
    loop { unsafe { asm { "cli; hlt" } } }
}

#[interrupt]
f timer_handler() {
    scheduler_tick()
    pic_eoi(0)
}

-- ─────────────────────────────────────────────
-- syscall dispatch
-- ─────────────────────────────────────────────

#[callconv("sysv64")]
f syscall_entry(nr: u64, a: u64, b: u64, c: u64, d: u64) = r: u64 {
    match nr {
        0 -> r = sys_read(a, b as *u8, c),
        1 -> r = sys_write(a, b as *u8, c),
        2 -> r = sys_exit(a as i32),
        _ -> r = 0xFFFFFFFFFFFFFFFF,   -- -1, unknown syscall
    }
}

f sys_read(fd: u64, buf: *u8, len: u64) = r: u64 {
    -- stub
    r = 0
}

f sys_write(fd: u64, buf: *u8, len: u64) = r: u64 {
    for (0..len) |i| {
        uart_putc(*(buf + i))
    }
    r = len
}

f sys_exit(code: i32) = r: u64 {
    uart_puts("process exited\n")
    r = code as u64
}

-- ─────────────────────────────────────────────
-- page fault handler impl
-- ─────────────────────────────────────────────

f handle_page_fault(addr: u64) = r: !void {
    -- demand-zero for user heap region
    if addr >= 0x0000000000400000 and addr < 0x0000800000000000 {
        *u8 page = raw_alloc(4096)
        if page == 0 as *u8 {
            r = error.MapError.OutOfMemory
            return
        }
        memset(page, 0, 4096)
        -- map it (simplified)
        try map_page(addr & 0xFFFFFFFFFFFFF000, page as u64, 0x7)
    } else {
        r = error.MapError.InvalidAddress
    }
}

-- ─────────────────────────────────────────────
-- VM setup
-- ─────────────────────────────────────────────

f setup_paging() = r: !void {
    regional f make_tables() = out: (*PageTable, *PageTable) {
        PageTable pml4 = PageTable.new()
        PageTable pdpt = PageTable.new()

        *PageTable h_pml4 = promote(&pml4) as dynamic
        *PageTable h_pdpt = promote(&pdpt) as dynamic

        out = (h_pml4, h_pdpt)
    }

    *PageTable pml4, *PageTable pdpt = make_tables()

    -- identity-map first 2MB
    u64 addr = 0
    while addr < 0x200000 {
        match pml4.map(addr, addr, 0x3) {
            Ok(_)                        -> {},
            Err(MapError.AlreadyMapped)  -> {},
            Err(e)                       -> {
                r = e
                return
            },
        }
        addr = addr + 4096
    }

    -- map kernel higher-half
    try pml4.map(0xFFFF800000000000, KERNEL_START, 0x3)

    unsafe { asm { "mov %rax, %cr3" } }
}

-- ─────────────────────────────────────────────
-- Scheduler stubs
-- ─────────────────────────────────────────────

f scheduler_tick() {
    -- round-robin: pop head, run, push tail
    loop {
        if task_queue_empty() { break }
        Task t = task_queue_pop()
        t.run()
        task_queue_push(t)
        break   -- one task per tick
    }
}

f pic_eoi(irq: u8) {
    volatile *u8 pic1 = 0x20 as *u8
    volatile *u8 pic2 = 0xA0 as *u8
    if irq >= 8 { *pic2 = 0x20 }
    *pic1 = 0x20
}

-- ─────────────────────────────────────────────
-- Kernel main
-- ─────────────────────────────────────────────

pub f kernel_main() {
    -- Paging
    setup_paging() catch |e| {
        uart_puts("paging setup failed\n")
        loop { unsafe { asm { "cli; hlt" } } }
    }

    uart_puts("paging OK\n")

    -- Enable interrupts
    unsafe { asm { "sti" } }

    -- Userspace
    gc f run_userspace() {
        f validate_task(t: Task) = r: bool {
            r = t.id > 0 and t.name.len > 0
        }

        Task shell = Task(id: 1, name: "shell", state: 0)

        if validate_task(shell) {
            task_queue_push(shell)
        }

        while true {
            scheduler_tick()
        }
    }

    run_userspace()
}

-- ─────────────────────────────────────────────
-- Entry point — the actual _start
-- ─────────────────────────────────────────────

#[section(".text.boot")]
#[link_name("_start")]
pub f entry_point() {
    -- Zero BSS before anything touches it
    u64 bss_len = BSS_END - BSS_START
    memset(BSS_START as *u8, 0, bss_len)

    kernel_main()

    -- Unreachable
    loop { unsafe { asm { "cli; hlt" } } }
}
